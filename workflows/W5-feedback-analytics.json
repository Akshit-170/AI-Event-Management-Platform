    {
      "parameters": {
        "jsCode": "const participants = $('Read Registration & Attendance Data').all().map(i => i.json);\nconst feedback = $('Read Feedback Data').all().map(i => i.json);\nconst ratings = feedback.map(f => Number(f.rating)).filter(r => !isNaN(r));\nconst avgRating = ratings.length ? (ratings.reduce((a, b) => a + b, 0) / ratings.length) : null;\nreturn [{ json: {\n  participantCount: participants.length,\n  feedbackCount: feedback.length,\n  averageRating: avgRating,\n  participants,\n  feedback,\n} }];"
      },
      "id": "27949eb2-e206-43d3-9cbc-7b1aec3ee2cb",
      "name": "Prepare Report Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
