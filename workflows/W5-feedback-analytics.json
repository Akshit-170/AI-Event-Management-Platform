        544
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an event analytics assistant. Write a concise weekly analytics report for the event organizers based on the data below.\n\nRegistered/attended participants: {{ $json.participantCount }}\nFeedback responses: {{ $json.feedbackCount }}\nAverage rating: {{ $json.averageRating }}\n\nParticipant data (JSON): {{ JSON.stringify($json.participants) }}\nFeedback data with AI sentiment/theme tags (JSON): {{ JSON.stringify($json.feedback) }}\n\nCover: overall attendance vs registration, feedback participation rate, sentiment breakdown, recurring themes, and 2-3 concrete recommendations. Use clear plain-text sections with headings.",
        "batching": {}
      },
